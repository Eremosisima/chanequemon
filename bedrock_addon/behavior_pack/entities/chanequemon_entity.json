{
  "format_version": "1.21.0",
  "minecraft:entity": {
    "description": {
      "identifier": "chanequemon:generic_creature",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "chanequemon:summoned": {
        "minecraft:follow_range": { "value": 32 },
        "minecraft:behavior.follow_owner": {
          "priority": 1,
          "speed_multiplier": 1.2,
          "start_distance": 6,
          "stop_distance": 2
        },
        "minecraft:behavior.look_at_player": {
          "priority": 2,
          "look_distance": 8
        },
        "minecraft:persistent": {}
      },
      "chanequemon:lectern": {
        "minecraft:behavior.wander": {
          "priority": 1,
          "speed_multiplier": 0.6,
          "xz_dist": 12,
          "y_dist": 3
        },
        "minecraft:behavior.look_at_player": {
          "priority": 2,
          "look_distance": 6
        },
        "minecraft:persistent": {}
      },
      "chanequemon:hostile": {
        "minecraft:behavior.melee_attack": {
          "priority": 1,
          "speed_multiplier": 1.0,
          "track_target": true
        },
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 2,
          "entity_types": [
            { "filters": { "test": "is_family", "subject": "other", "value": "player" } }
          ]
        },
        "minecraft:health": { "value": 60, "max": 60 }
      },
      "chanequemon:spirit_visual": {
        "minecraft:collision_box": { "width": 0.5, "height": 0.8 },
        "minecraft:scale": { "value": 0.8 },
        "minecraft:type_family": { "family": ["chanequemon", "spirit", "mob"] },
        "minecraft:damage_sensor": {
          "triggers": [
            { "on_damage": { "filters": { "test": "is_family", "value": "chanequemon" }, "cause": "all" }, "damage_modifier": 0.3 }
          ]
        }
      },
      "chanequemon:beast_visual": {
        "minecraft:collision_box": { "width": 1.0, "height": 1.2 },
        "minecraft:scale": { "value": 1.0 },
        "minecraft:type_family": { "family": ["chanequemon", "beast", "mob"] }
      },
      "chanequemon:dragon_visual": {
        "minecraft:collision_box": { "width": 2.0, "height": 2.5 },
        "minecraft:scale": { "value": 1.5 },
        "minecraft:type_family": { "family": ["chanequemon", "dragon", "mob"] }
      }
    },
    "components": {
      "minecraft:type_family": { "family": ["chanequemon", "mob"] },
      "minecraft:health": { "value": 40, "max": 40 },
      "minecraft:movement": { "value": 0.25 },
      "minecraft:movement.basic": {},
      "minecraft:navigation.walk": { "can_path_over_water": true },
      "minecraft:collision_box": { "width": 0.6, "height": 1.0 },
      "minecraft:nameable": { "allow_name_tag_renaming": true },
      "minecraft:leashable": { "soft_distance": 4, "hard_distance": 6 },
      "minecraft:despawn": { "despawn_from_distance": {} },
      "minecraft:scale": { "value": 1.0 },
      "minecraft:fire_immune": false,
      "minecraft:damage_sensor": {
        "triggers": [
          { "on_damage": { "filters": { "test": "is_family", "value": "chanequemon" }, "cause": "all" }, "damage_modifier": 0.5 }
        ]
      }
    },
    "events": {
      "chanequemon:set_summoned": {
        "add": { "component_groups": ["chanequemon:summoned", "chanequemon:spirit_visual"] }
      },
      "chanequemon:set_lectern": {
        "add": { "component_groups": ["chanequemon:lectern", "chanequemon:spirit_visual"] }
      },
      "chanequemon:set_beast": {
        "add": { "component_groups": ["chanequemon:summoned", "chanequemon:beast_visual"] }
      },
      "chanequemon:set_dragon": {
        "add": { "component_groups": ["chanequemon:summoned", "chanequemon:dragon_visual"] }
      },
      "chanequemon:set_hostile": {
        "add": { "component_groups": ["chanequemon:hostile"] }
      },
      "minecraft:entity_spawned": {}
    }
  }
}
